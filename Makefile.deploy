# Makefile.deploy — cross-compile picoclaw for Raspberry Pi and deploy via SSH
#
# Usage (from the repo root, via Git Bash on Windows or any POSIX shell):
#
#   make -f Makefile.deploy build-pi        # cross-compile for linux/arm64
#   make -f Makefile.deploy deploy          # build + push binary + skills + config
#   make -f Makefile.deploy logs            # tail journalctl on Pi
#   make -f Makefile.deploy rollback        # revert to previous binary
#
# Prerequisites:
#   - Go 1.25+ in PATH
#   - SSH access to PI_HOST (key-based recommended)
#   - rsync available (Git Bash ships it; or use WSL)
#   - GitHub PAT (see section below)
#
# PI_HOST must resolve — use Tailscale hostname or bare IP.
# On Windows, run this Makefile from Git Bash (not PowerShell directly).
#
# ## GitHub PAT
# The deployment requires a fine-grained Personal Access Token (PAT) for GitHub integration.
# Scope required:
#   - Read-only: Contents, Issues, Pull requests, Commit statuses, Metadata
#   - Write: Issues only (required for the `/claude <repo>` flow to create inquiry issues)
#   - Limit scope to repositories listed in `watched_repos` in `deploy/config.yaml`
# To mint: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
# Add to the Pi: Insert `GITHUB_PAT=ghp_xxxxx` into `secrets.env`
# Recommended expiration: 90 days; renew manually when approaching expiry
#
# ## Failure Alert Bot + Scheduler (Chunk 11)
# The failure alert bot notifies you when the main bot crashes, and the scheduler enables
# regular briefings (e.g., daily briefing at 08:00). Both require one-time setup.
#
# Alert Bot Token:
#   1. Create a separate Telegram bot via @BotFather (suggested name: "PicoClaw Alerts")
#   2. Get the bot token and your Telegram user ID (same as allowed_users in config.yaml)
#   3. SSH to the Pi as root and create /etc/picoclaw/:
#      sudo mkdir -p /etc/picoclaw
#      echo "TOKEN_HERE" | sudo tee /etc/picoclaw/telegram-alert-token > /dev/null
#      sudo chmod 600 /etc/picoclaw/telegram-alert-token
#      echo "CHAT_ID_HERE" | sudo tee /etc/picoclaw/telegram-alert-chatid > /dev/null
#      sudo chmod 600 /etc/picoclaw/telegram-alert-chatid
#
# Alert Script & Service:
#   4. sudo cp deploy/on-failure.sh /usr/local/bin/picoclaw-alert.sh
#      sudo chmod 755 /usr/local/bin/picoclaw-alert.sh
#      sudo cp deploy/picoclaw-alert.service /etc/systemd/system/
#      sudo chmod 644 /etc/systemd/system/picoclaw-alert.service
#      sudo systemctl daemon-reload
#
# Wire OnFailure Directive:
#   5. Edit /etc/systemd/system/picoclaw.service (the main bot unit)
#      Add "OnFailure=picoclaw-alert.service" under [Unit] section, then:
#      sudo systemctl daemon-reload
#
# Verify Alert Setup:
#   6. sudo systemctl stop picoclaw (expect Telegram alert within ~5 seconds)
#      sudo systemctl start picoclaw
#      sudo journalctl -u picoclaw-alert.service -n 20
#
# Scheduler Config (optional, no external setup):
#   7. Edit deploy/config.yaml and add: tools.scheduler.briefing_time: "08:00"
#      Reminders and briefings use existing Gmail/Outlook/GCal/GitHub credentials.
#
# ## State Backup Setup (Chunk D — laptop dev)
# Backs up workspace/state/ (reminders, scheduler state, polls, proposals) and secrets.env
# (encrypted) to wiki-mirror/state-backup/ for daily snapshots pushed to private GitHub.
#
# Prerequisites:
#   - age tool installed (https://github.com/FiloSottile/age)
#   - wiki-mirror sibling repo cloned at /home/picoclaw/wiki-mirror on the Pi
#   - The picoclaw user MUST have push access to the wiki-mirror remote, or
#     the daily git push will fail silently in the journal. Either:
#       (a) SSH: register /home/picoclaw/.ssh/id_ed25519.pub as a deploy key
#           on the wiki-mirror GitHub repo with write access, and confirm
#           the remote is SSH (`git remote -v` shows git@github.com:...)
#       (b) HTTPS: a fine-grained PAT cached via git-credential-store
#     Verify before enabling the timer: sudo -u picoclaw git -C /home/picoclaw/wiki-mirror push --dry-run
#
# Laptop-side setup (one-time):
#   1. Generate age keypair on your laptop (do NOT generate on the Pi):
#      age-keygen -o ~/picoclaw-restore.key
#      This creates both the private and public key. Store the private key securely
#      (password manager, offline media). Losing it means encrypted secrets.env is unrecoverable.
#
#   2. Extract the public key (the line starting "# public key:") and copy to the Pi:
#      cat ~/picoclaw-restore.key | grep "^# public key:" | sed 's/# public key: //' > /tmp/age-recipient.pub
#      scp /tmp/age-recipient.pub picoclaw@pi-assistant:/tmp/
#      ssh picoclaw@pi-assistant 'sudo install -m 0644 -o root -g root /tmp/age-recipient.pub /etc/picoclaw/age-recipient.pub'
#
# Pi-side setup (SSH into the Pi as your user, then sudo):
#   3. Adjust secrets.env to be group-readable by picoclaw:
#      sudo chgrp picoclaw /etc/picoclaw/secrets.env
#      sudo chmod 0640 /etc/picoclaw/secrets.env
#
#   4. Deploy backup script and systemd units:
#      sudo install -m 0755 -o root -g root deploy/state-backup.sh /usr/local/bin/picoclaw-state-backup.sh
#      sudo install -m 0644 -o root -g root deploy/picoclaw-state-backup.service /etc/systemd/system/
#      sudo install -m 0644 -o root -g root deploy/picoclaw-state-backup.timer /etc/systemd/system/
#      sudo systemctl daemon-reload
#      sudo systemctl enable --now picoclaw-state-backup.timer
#
#   5. Verify setup:
#      systemctl list-timers picoclaw-state-backup.timer
#      sudo systemctl start picoclaw-state-backup.service  # one-shot test run
#      journalctl -u picoclaw-state-backup.service -n 30
#      ls -la /home/picoclaw/wiki-mirror/state-backup/
#
# Restore (laptop-side, if needed):
#   - Decrypt secrets:
#     age --decrypt --identity ~/picoclaw-restore.key \
#         --output secrets.env wiki-mirror/state-backup/secrets.env.age
#   - Extract state snapshot:
#     mkdir -p /tmp/restore
#     tar -xzf wiki-mirror/state-backup/state-YYYY-MM-DD.tar.gz -C /tmp/restore
#
# Standalone PowerShell build commands (no make required):
#   # 1. Generate the embedded workspace using the HOST arch (no GOOS/GOARCH set):
#   Remove-Item Env:GOOS, Env:GOARCH, Env:CGO_ENABLED -ErrorAction SilentlyContinue
#   go generate ./cmd/picoclaw/internal/onboard/...
#   # 2. Cross-compile for the Pi:
#   $env:GOOS="linux"; $env:GOARCH="arm64"; $env:CGO_ENABLED="0"
#   go build -tags "goolm,stdjson,no_matrix" -ldflags="-s -w" -o build/picoclaw-arm64 ./cmd/picoclaw

PI_HOST  ?= picoclaw@pi-assistant
GOARCH   ?= arm64
GOOS     ?= linux
BUILD_DIR = build

# Build tags:
#   no_matrix  — drops the Matrix channel (avoids libolm/CGO when building without goolm)
#   goolm      — pure-Go OLM implementation (matches upstream Makefile default; belt-and-suspenders)
#   stdjson    — standard library JSON codec
BUILD_TAGS = goolm,stdjson,no_matrix

LDFLAGS = -s -w

ifeq ($(OS),Windows_NT)
	POWERSHELL = powershell -NoProfile -Command
endif

.PHONY: all build-pi build-runshell _prepare-workspace deploy-binary deploy-skills deploy-config deploy logs rollback

all: build-pi build-runshell

## _prepare-workspace: Populate the embedded workspace (go generate)
ifeq ($(OS),Windows_NT)
_prepare-workspace:
	@echo "Preparing embedded workspace (go generate) ..."
	$(POWERSHELL) "Remove-Item Env:GOOS, Env:GOARCH, Env:CGO_ENABLED -ErrorAction SilentlyContinue; go generate ./cmd/picoclaw/internal/onboard/..."
else
_prepare-workspace:
	@echo "Preparing embedded workspace (go generate) ..."
	GOOS=$$(go env GOHOSTOS) GOARCH=$$(go env GOHOSTARCH) CGO_ENABLED=$$(go env CGO_ENABLED) go generate ./cmd/picoclaw/internal/onboard/...
endif

## build-pi: Cross-compile picoclaw for linux/arm64
ifeq ($(OS),Windows_NT)
build-pi: _prepare-workspace
	@echo "Building picoclaw for $(GOOS)/$(GOARCH) ..."
	$(POWERSHELL) "\
		$$env:GOOS='$(GOOS)'; \
		$$env:GOARCH='$(GOARCH)'; \
		$$env:CGO_ENABLED='0'; \
		New-Item -ItemType Directory -Force -Path '$(BUILD_DIR)' | Out-Null; \
		go build -tags '$(BUILD_TAGS)' -ldflags '$(LDFLAGS)' \
		  -o '$(BUILD_DIR)/picoclaw-$(GOARCH)' ./cmd/picoclaw"
	@echo "Binary: $(BUILD_DIR)/picoclaw-$(GOARCH)"
else
build-pi: _prepare-workspace
	@echo "Building picoclaw for $(GOOS)/$(GOARCH) ..."
	mkdir -p $(BUILD_DIR)
	GOOS=$(GOOS) GOARCH=$(GOARCH) CGO_ENABLED=0 \
		go build \
		-tags "$(BUILD_TAGS)" \
		-ldflags "$(LDFLAGS)" \
		-o $(BUILD_DIR)/picoclaw-$(GOARCH) \
		./cmd/picoclaw
	@echo "Binary: $(BUILD_DIR)/picoclaw-$(GOARCH)"
endif

## build-runshell: Cross-compile the privsep helper for linux/arm64
ifeq ($(OS),Windows_NT)
build-runshell:
	@echo "Building picoclaw-runshell for $(GOOS)/$(GOARCH) ..."
	$(POWERSHELL) "\
		$$env:GOOS='$(GOOS)'; \
		$$env:GOARCH='$(GOARCH)'; \
		$$env:CGO_ENABLED='0'; \
		New-Item -ItemType Directory -Force -Path '$(BUILD_DIR)' | Out-Null; \
		go build -ldflags '$(LDFLAGS)' \
		  -o '$(BUILD_DIR)/picoclaw-runshell-$(GOARCH)' ./cmd/picoclaw-runshell"
	@echo "Binary: $(BUILD_DIR)/picoclaw-runshell-$(GOARCH)"
else
build-runshell:
	@echo "Building picoclaw-runshell for $(GOOS)/$(GOARCH) ..."
	mkdir -p $(BUILD_DIR)
	GOOS=$(GOOS) GOARCH=$(GOARCH) CGO_ENABLED=0 \
		go build \
		-ldflags "$(LDFLAGS)" \
		-o $(BUILD_DIR)/picoclaw-runshell-$(GOARCH) \
		./cmd/picoclaw-runshell
	@echo "Binary: $(BUILD_DIR)/picoclaw-runshell-$(GOARCH)"
endif

## deploy-binary: Build then install binaries on Pi via SSH/SCP
deploy-binary: build-pi build-runshell
	ssh $(PI_HOST) 'sudo cp /usr/local/bin/picoclaw /usr/local/bin/picoclaw.prev 2>/dev/null || true'
	ssh $(PI_HOST) 'sudo cp /usr/local/bin/picoclaw-runshell /usr/local/bin/picoclaw-runshell.prev 2>/dev/null || true'
	scp $(BUILD_DIR)/picoclaw-$(GOARCH)           $(PI_HOST):/tmp/picoclaw.new
	scp $(BUILD_DIR)/picoclaw-runshell-$(GOARCH)  $(PI_HOST):/tmp/picoclaw-runshell.new
	ssh $(PI_HOST) '\
		sudo mv /tmp/picoclaw.new /usr/local/bin/picoclaw && \
		sudo mv /tmp/picoclaw-runshell.new /usr/local/bin/picoclaw-runshell && \
		sudo chmod +x /usr/local/bin/picoclaw /usr/local/bin/picoclaw-runshell && \
		sudo systemctl restart picoclaw'

## deploy-skills: Sync built-in skills to the Pi workspace
deploy-skills:
	rsync -av --delete workspace/skills/ $(PI_HOST):/home/picoclaw/skills/

## deploy-config: Push config.yaml to the Pi and restart
deploy-config:
	scp deploy/config.yaml $(PI_HOST):/home/picoclaw/config.yaml
	ssh $(PI_HOST) 'sudo systemctl restart picoclaw'

## deploy: Full deploy — binary + skills + config
deploy: deploy-binary deploy-skills deploy-config

## logs: Tail picoclaw journal on the Pi
logs:
	ssh $(PI_HOST) 'sudo journalctl -u picoclaw -f'

## rollback: Stop picoclaw, restore previous binaries, restart
rollback:
	ssh $(PI_HOST) '\
		sudo systemctl stop picoclaw && \
		sudo cp /usr/local/bin/picoclaw.prev /usr/local/bin/picoclaw && \
		if [ -f /usr/local/bin/picoclaw-runshell.prev ]; then \
		  sudo cp /usr/local/bin/picoclaw-runshell.prev /usr/local/bin/picoclaw-runshell; \
		fi && \
		sudo systemctl start picoclaw'
